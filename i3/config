#gaps
    #default gap size
    # gaps inner 10
    # gaps inner 20
    gaps inner 3
    # gaps outer 5
    gaps outer 0
    # gaps outer 30
    # smart_gaps on
    #smart_borders on

    #keybindings toggle gaps - todo
    bindsym $mod+F1 gaps inner current set 0; gaps outer current set 0
    bindsym $mod+F2 gaps inner current set 35; gaps outer current set 10
